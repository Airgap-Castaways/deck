{
  "$id": "https://deck.local/schemas/tools/package.install-dnf.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Install packages on RHEL-family nodes with dnf.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1",
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "InstallDnfPackage"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "parallelGroup": {
      "minLength": 1,
      "type": "string"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "$id": "https://github.com/Airgap-Castaways/deck/internal/stepspec/install-dnf-package",
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "dnf": {
          "additionalProperties": false,
          "description": "Dnf-specific installation options.",
          "examples": [
            "{skipBroken:true,allowErasing:true}"
          ],
          "properties": {
            "allowErasing": {
              "description": "Allow erasing installed packages to resolve dependencies.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "best": {
              "description": "Prefer best available versions. Omit to use the distribution default.",
              "examples": [
                "false"
              ],
              "type": "boolean"
            },
            "cacheOnly": {
              "description": "Use only cached metadata and packages.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "disableGpgCheck": {
              "description": "Disable GPG signature checking for this transaction.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "excludePackages": {
              "description": "Package name patterns to exclude from the transaction.",
              "examples": [
                "[kernel*]"
              ],
              "items": {
                "minLength": 1,
                "type": "string"
              },
              "type": "array"
            },
            "installWeakDeps": {
              "description": "Install weak dependencies. Omit to use the distribution default.",
              "examples": [
                "false"
              ],
              "type": "boolean"
            },
            "skipBroken": {
              "description": "Skip unavailable packages or packages with broken dependencies.",
              "examples": [
                "true"
              ],
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "excludeRepos": {
          "description": "Dnf repository IDs to exclude from package resolution.",
          "examples": [
            "[updates]"
          ],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "packages": {
          "description": "Package names to install.",
          "examples": [
            "[kubelet,kubeadm,kubectl]"
          ],
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "restrictToRepos": {
          "description": "Limit dnf visibility to these repository IDs.",
          "examples": [
            "[offline-kubernetes]"
          ],
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "type": "array"
        },
        "source": {
          "additionalProperties": false,
          "description": "Local repository source used for the installation.",
          "examples": [
            "{type:local-repo,path:/opt/deck/repos/kubernetes}"
          ],
          "properties": {
            "path": {
              "description": "Filesystem path to the pre-prepared local package repository.",
              "examples": [
                "/opt/deck/repos/kubernetes"
              ],
              "minLength": 1,
              "type": "string"
            },
            "type": {
              "const": "local-repo",
              "description": "Source type. Currently only `local-repo` is supported.",
              "examples": [
                "local-repo"
              ]
            }
          },
          "required": [
            "type",
            "path"
          ],
          "type": "object"
        }
      },
      "required": [
        "packages"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "InstallDnfPackageStep",
  "type": "object",
  "x-deck-visibility": "public"
}
