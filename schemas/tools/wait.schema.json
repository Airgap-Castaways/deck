{
  "$id": "https://deck.local/schemas/tools/wait.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Waits for healthcheck-style conditions through action-specific polling.",
  "properties": {
    "apiVersion": {
      "const": "deck/v1alpha1"
    },
    "id": {
      "type": "string"
    },
    "kind": {
      "const": "Wait"
    },
    "metadata": {
      "additionalProperties": true,
      "type": "object"
    },
    "register": {
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
      },
      "type": "object"
    },
    "retry": {
      "minimum": 0,
      "type": "integer"
    },
    "spec": {
      "additionalProperties": false,
      "allOf": [
        {
          "allOf": [
            {
              "if": {
                "properties": {
                  "action": {
                    "const": "commandSuccess"
                  }
                },
                "required": [
                  "action"
                ]
              },
              "then": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "name"
                      ]
                    },
                    {
                      "required": [
                        "path"
                      ]
                    },
                    {
                      "required": [
                        "type"
                      ]
                    },
                    {
                      "required": [
                        "nonEmpty"
                      ]
                    },
                    {
                      "required": [
                        "address"
                      ]
                    },
                    {
                      "required": [
                        "port"
                      ]
                    }
                  ]
                }
              }
            },
            {
              "if": {
                "properties": {
                  "action": {
                    "const": "fileAbsent"
                  }
                },
                "required": [
                  "action"
                ]
              },
              "then": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "name"
                      ]
                    },
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "nonEmpty"
                      ]
                    },
                    {
                      "required": [
                        "address"
                      ]
                    },
                    {
                      "required": [
                        "port"
                      ]
                    }
                  ]
                }
              }
            },
            {
              "if": {
                "properties": {
                  "action": {
                    "const": "fileExists"
                  }
                },
                "required": [
                  "action"
                ]
              },
              "then": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "name"
                      ]
                    },
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "address"
                      ]
                    },
                    {
                      "required": [
                        "port"
                      ]
                    }
                  ]
                }
              }
            },
            {
              "if": {
                "properties": {
                  "action": {
                    "const": "serviceActive"
                  }
                },
                "required": [
                  "action"
                ]
              },
              "then": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "path"
                      ]
                    },
                    {
                      "required": [
                        "type"
                      ]
                    },
                    {
                      "required": [
                        "nonEmpty"
                      ]
                    },
                    {
                      "required": [
                        "address"
                      ]
                    },
                    {
                      "required": [
                        "port"
                      ]
                    }
                  ]
                }
              }
            },
            {
              "if": {
                "properties": {
                  "action": {
                    "const": "tcpPortClosed"
                  }
                },
                "required": [
                  "action"
                ]
              },
              "then": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "name"
                      ]
                    },
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "path"
                      ]
                    },
                    {
                      "required": [
                        "type"
                      ]
                    },
                    {
                      "required": [
                        "nonEmpty"
                      ]
                    }
                  ]
                }
              }
            },
            {
              "if": {
                "properties": {
                  "action": {
                    "const": "tcpPortOpen"
                  }
                },
                "required": [
                  "action"
                ]
              },
              "then": {
                "not": {
                  "anyOf": [
                    {
                      "required": [
                        "name"
                      ]
                    },
                    {
                      "required": [
                        "command"
                      ]
                    },
                    {
                      "required": [
                        "path"
                      ]
                    },
                    {
                      "required": [
                        "type"
                      ]
                    },
                    {
                      "required": [
                        "nonEmpty"
                      ]
                    }
                  ]
                }
              }
            }
          ]
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "serviceActive"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "name"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "commandSuccess"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "command"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "fileExists",
                  "fileAbsent"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "path"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "tcpPortClosed",
                  "tcpPortOpen"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "port"
            ]
          }
        }
      ],
      "properties": {
        "action": {
          "enum": [
            "serviceActive",
            "commandSuccess",
            "fileExists",
            "fileAbsent",
            "tcpPortClosed",
            "tcpPortOpen"
          ],
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "command": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        },
        "initialDelay": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "interval": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "nonEmpty": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "pollInterval": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "port": {
          "type": "string"
        },
        "timeout": {
          "pattern": "^[0-9]+(ms|s|m|h)$",
          "type": "string"
        },
        "type": {
          "enum": [
            "any",
            "file",
            "dir"
          ],
          "type": "string"
        }
      },
      "required": [
        "action"
      ],
      "type": "object"
    },
    "timeout": {
      "pattern": "^[0-9]+(ms|s|m|h)$",
      "type": "string"
    },
    "when": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "kind",
    "spec"
  ],
  "title": "WaitStep",
  "type": "object",
  "x-deck-visibility": "public"
}
