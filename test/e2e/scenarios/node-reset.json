{
  "nodes": ["control-plane", "worker", "worker-2"],
  "kubernetesVersion": "v1.30.1",
  "verify": {
    "defaultStage": "all",
    "stages": {
      "all": [
        {
          "id": "06-verify-node-reset-worker",
          "role": "worker",
          "workflow": "scenarios/node-reset-worker-verify.yaml"
        },
        {
          "id": "06-verify-node-reset-cluster",
          "role": "control-plane",
          "workflow": "scenarios/node-reset-cluster-verify.yaml"
        }
      ]
    }
  },
  "apply": [
    {
      "id": "04-bootstrap-control-plane",
      "role": "control-plane",
      "workflow": "scenarios/control-plane-bootstrap.yaml"
    },
    {
      "id": "05-join-worker",
      "role": "worker",
      "workflow": "scenarios/worker-join-debian.yaml"
    },
    {
      "id": "05-reset-worker",
      "role": "worker",
      "workflow": "scenarios/node-reset.yaml"
    },
    {
      "id": "05-rejoin-worker",
      "role": "worker",
      "workflow": "scenarios/worker-rejoin-debian.yaml"
    },
    {
      "id": "05-join-worker-2",
      "role": "worker-2",
      "workflow": "scenarios/worker-join-rhel.yaml"
    }
  ],
  "resultEvidenceFiles": {
    "clusterNodes": "reports/cluster-nodes.txt",
    "pods": "reports/kube-system-pods.txt",
    "workerApply": "reports/worker-apply.txt",
    "worker2Apply": "reports/worker-2-apply.txt",
    "workerReset": "reports/reset-state.txt",
    "workerRejoin": "reports/worker-rejoin.txt",
    "resetState": "reports/reset-state.txt",
    "kubeletRejoinState": "reports/rejoin-kubelet.txt"
  },
  "requiredArtifacts": [
    {
      "path": "reports/cluster-nodes.txt"
    },
    {
      "path": "reports/kube-system-pods.txt"
    },
    {
      "path": "reports/worker-apply.txt"
    },
    {
      "path": "reports/worker-2-apply.txt"
    },
    {
      "path": "reports/worker-rejoin.txt"
    },
    {
      "path": "reports/reset-state.txt",
      "contains": ["kubeadmReset=ok", "containerd=active", "kubeletService=active"]
    },
    {
      "path": "reports/rejoin-kubelet.txt",
      "contains": ["kubeletServiceAfterRejoin=active", "kubeletConfigAfterRejoin=present"]
    }
  ]
}
