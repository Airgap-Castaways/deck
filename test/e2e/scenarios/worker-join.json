{
  "nodes": ["control-plane", "worker", "worker-2"],
  "kubernetesVersion": "v1.30.1",
  "verify": {
    "defaultStage": "cluster",
    "stages": {
      "cluster": [
        {
          "id": "06-verify-cluster",
          "role": "control-plane",
          "workflow": "scenarios/worker-join-cluster-verify.yaml"
        }
      ]
    }
  },
  "apply": [
    {
      "id": "04-bootstrap-control-plane",
      "role": "control-plane",
      "workflow": "scenarios/control-plane-bootstrap.yaml"
    },
    {
      "id": "05-join-worker",
      "role": "worker",
      "workflow": "scenarios/worker-join-debian.yaml"
    },
    {
      "id": "05-join-worker-2",
      "role": "worker-2",
      "workflow": "scenarios/worker-join-rhel.yaml"
    }
  ],
  "resultEvidenceFiles": {
    "clusterNodes": "reports/cluster-nodes.txt",
    "pods": "reports/kube-system-pods.txt",
    "workerApply": "reports/worker-apply.txt",
    "worker2Apply": "reports/worker-2-apply.txt"
  },
  "requiredArtifacts": [
    {
      "path": "reports/cluster-nodes.txt"
    },
    {
      "path": "reports/kube-system-pods.txt"
    },
    {
      "path": "reports/worker-apply.txt"
    },
    {
      "path": "reports/worker-2-apply.txt"
    }
  ]
}
